classDiagram
    class User {
        +String userId
        +String name
        +String email
        +String password
        +String phoneNumber
        +createProfile()
        +addPet()
        +editProfile()
        +viewPets()
    }

    class Pet {
        +String petId
        +String name
        +int age
        +String type
        +String breed
        +float weight
        +String healthNotes
        +String specialNeeds
        +updatePetDetails()
        +viewPetProfile()
        +getPetCareNeeds()
    }

    class Task {
        +String taskId
        +String taskName
        +String taskType
        +String description
        +String priority
        +String dueTime
        +String status
        +String frequency
        +createTask()
        +updateTask()
        +markTaskCompleted()
        +setPriority()
    }

    class Schedule {
        +String scheduleId
        +String date
        +List taskList
        +addTaskToSchedule()
        +removeTaskFromSchedule()
        +sortTasksByPriority()
        +viewSchedule()
    }

    class Plan {
        +String planId
        +String date
        +String petId
        +List dailyTasks
        +String planReason
        +generateDailyPlan()
        +explainPlan()
        +updatePlan()
    }

    User "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Schedule "1" --> "many" Task : organizes
    Plan "1" --> "1" Pet : created for
    Plan "1" --> "many" Task : includes
